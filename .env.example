# Skopiuj do .env i uzupelnij. NIE commituj .env do repo.
OPENAI_API_KEY=sk-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
DIGEST_LANGUAGE=polski
LOOKBACK_HOURS=24
MAX_ITEMS_TO_MODEL=80
MAX_PER_FEED=8
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
MODEL_MAX_RETRIES=3
# Dedup miedzy biegami (historia wyslanych URL-i). W GitHub Actions plik
# trzymany jest w cache; lokalnie powstaje w .state/ (ignorowane przez git).
SENT_HISTORY_FILE=.state/sent.json
SENT_HISTORY_DAYS=7
